{
  "typescript.disableAutomaticTypeAcquisition": true,
  "typescript.preferences.includePackageJsonAutoImports": "auto",
  "javascript.preferences.includePackageJsonAutoImports": "auto",
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/coverage": true
  },
  "files.exclude": {
    "**/.next": true,
    "**/dist": true,
    "**/coverage": true
  },
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/dist/**": true,
    "**/coverage/**": true,
    "**/node_modules/**": true
  }
}
